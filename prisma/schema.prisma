generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WorksheetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorksheetVisibility {
  PRIVATE
  PUBLIC
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  MIXED
}

enum WorksheetType {
  PRACTICE
  QUIZ
  EXIT_TICKET
  HOMEWORK
  ASSESSMENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  CHECKBOX
  SHORT_ANSWER
  LONG_ANSWER
  TRUE_FALSE
  FILL_IN_THE_BLANK
  MATCHING
  ORDERING
  NUMERIC
  IMAGE_QUESTION
}

enum InputSourceType {
  STUDENT_GOAL
  TEXT_PROMPT
  FILE_UPLOAD
  URL
  VIDEO_LINK
}

model User {
  id                  String                @id @default(cuid())
  name                String
  email               String                @unique
  role                String                @default("teacher")
  worksheets          Worksheet[]
  worksheetDrafts     WorksheetDraft[]
  assignmentsCreated  WorksheetAssignment[] @relation("AssignmentCreator")
  assignmentStudents  AssignmentStudent[]
  worksheetResponses  WorksheetResponse[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model Worksheet {
  id                String                @id @default(cuid())
  ownerId           String
  owner             User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  grade             String
  subject           String
  skill             String?
  difficulty        DifficultyLevel       @default(MEDIUM)
  worksheetType     WorksheetType         @default(PRACTICE)
  status            WorksheetStatus       @default(DRAFT)
  visibility        WorksheetVisibility   @default(PRIVATE)
  questionCount     Int                   @default(0)
  estimatedMinutes  Int?
  sections          WorksheetSection[]
  assignments       WorksheetAssignment[]
  aiGenerations     AIGeneration[]
  tags              WorksheetTag[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  publishedAt       DateTime?
}

model WorksheetDraft {
  id            String   @id @default(cuid())
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  worksheetId   String?
  version       Int      @default(1)
  title         String
  draftPayload  Json
  autosaveAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorksheetSection {
  id           String     @id @default(cuid())
  worksheetId  String
  worksheet    Worksheet  @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  orderIndex   Int
  questions    Question[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([worksheetId, orderIndex])
}

model Question {
  id                   String         @id @default(cuid())
  sectionId            String
  section              WorksheetSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type                 QuestionType
  title                String
  prompt               String
  orderIndex           Int
  points               Float          @default(1)
  isRequired           Boolean        @default(true)
  hint                 String?
  explanation          String?
  imageUrl             String?
  options              QuestionOption[]
  correctAnswer        Json?
  settings             Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([sectionId, orderIndex])
}

model QuestionOption {
  id           String    @id @default(cuid())
  questionId   String
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label        String
  value        String
  orderIndex   Int
  isCorrect    Boolean   @default(false)
  matchKey     String?

  @@unique([questionId, orderIndex])
}

model WorksheetAssignment {
  id                 String              @id @default(cuid())
  worksheetId        String
  worksheet          Worksheet           @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  createdById        String
  createdBy          User                @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  title              String
  instructions       String?
  dueDate            DateTime?
  timeLimitMinutes   Int?
  attemptsAllowed    Int                 @default(1)
  shuffleQuestions   Boolean             @default(false)
  shareLink          String?             @unique
  isPublished        Boolean             @default(false)
  makePublic         Boolean             @default(false)
  students           AssignmentStudent[]
  responses          WorksheetResponse[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AssignmentStudent {
  id            String              @id @default(cuid())
  assignmentId  String
  assignment    WorksheetAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId     String
  student       User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedAt    DateTime            @default(now())
  status        String              @default("assigned")

  @@unique([assignmentId, studentId])
}

model WorksheetResponse {
  id                String              @id @default(cuid())
  assignmentId      String
  assignment        WorksheetAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  worksheetId       String
  studentId         String
  student           User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  responsePayload   Json
  score             Float?
  maxScore          Float?
  completionRate    Float?
  submittedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model AIGeneration {
  id               String          @id @default(cuid())
  worksheetId      String?
  worksheet        Worksheet?      @relation(fields: [worksheetId], references: [id], onDelete: SetNull)
  requestedById    String
  requestPayload   Json
  responsePayload  Json
  inputSource      InputSourceType
  prompt           String?
  createdAt        DateTime        @default(now())
}

model WorksheetTag {
  id           String      @id @default(cuid())
  worksheetId  String
  worksheet    Worksheet   @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  label        String

  @@unique([worksheetId, label])
}
